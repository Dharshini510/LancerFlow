{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A project managed by the freelancer",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Completed"] },
        "deadline": { "type": "string" },
        "clientId": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["name", "status", "clientId", "uid"]
    },
    "Client": {
      "title": "Client",
      "description": "A professional client",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "uid": { "type": "string" }
      },
      "required": ["name", "email", "uid"]
    },
    "Task": {
      "title": "Task",
      "description": "A task within a project or general",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["To Do", "Done"] },
        "dueDate": { "type": "string" },
        "projectId": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["title", "status", "uid"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A billing invoice",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Paid", "Unpaid"] },
        "date": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["title", "amount", "status", "uid"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["name", "email"]
    }
  },
  "firestore": {
    "projects": { "schema": "Project", "description": "Collection of projects" },
    "clients": { "schema": "Client", "description": "Collection of clients" },
    "tasks": { "schema": "Task", "description": "Collection of tasks" },
    "invoices": { "schema": "Invoice", "description": "Collection of invoices" },
    "users": { "schema": "User", "description": "Collection of user profiles" }
  }
}
